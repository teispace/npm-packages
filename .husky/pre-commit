#!/usr/bin/env sh

echo '🏗️👷 Checking your code before committing...'

# Run Biome check on staged files via lint-staged
echo '🔍 Linting and formatting staged files...'
yarn lint-staged

if [ $? -ne 0 ]; then
    echo '❌ Lint-staged failed. Please fix the errors and try again.'
    exit 1
fi

# Type check only staged TypeScript files
echo '🔎 Type checking staged files...'
STAGED_TS_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx)$' || true)

if [ -n "$STAGED_TS_FILES" ]; then
    yarn type-check
    if [ $? -ne 0 ]; then
        echo '❌ Type check failed. Please fix TypeScript errors.'
        exit 1
    fi
    echo '✅ Type check passed'
else
    echo '⏭️  No TypeScript files to check'
fi

echo '✅ Pre-commit checks passed! 🎉'
