{
  "name": "@teispace/env",
  "version": "0.2.2",
  "description": "Type-safe, validated environment variables for every JavaScript runtime and framework. Load, validate, coerce, and type your env — Node, Bun, Deno, Workers, Next, Nest, Vite, Nuxt, and more.",
  "type": "module",
  "license": "MIT",
  "author": "Teispace",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teispace/npm-packages.git",
    "directory": "packages/env"
  },
  "homepage": "https://github.com/teispace/npm-packages/tree/main/packages/env#readme",
  "bugs": {
    "url": "https://github.com/teispace/npm-packages/issues"
  },
  "keywords": [
    "env",
    "dotenv",
    "environment-variables",
    "config",
    "validation",
    "type-safe",
    "typescript",
    "zod",
    "valibot",
    "standard-schema",
    "nextjs",
    "nestjs",
    "vite",
    "nuxt",
    "deno",
    "bun",
    "cloudflare-workers"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./load": {
      "import": {
        "types": "./dist/load.d.ts",
        "default": "./dist/load.js"
      },
      "require": {
        "types": "./dist/load.d.cts",
        "default": "./dist/load.cjs"
      }
    },
    "./config": {
      "import": {
        "types": "./dist/config.d.ts",
        "default": "./dist/config.js"
      },
      "require": {
        "types": "./dist/config.d.cts",
        "default": "./dist/config.cjs"
      }
    },
    "./next": {
      "import": {
        "types": "./dist/presets/next.d.ts",
        "default": "./dist/presets/next.js"
      },
      "require": {
        "types": "./dist/presets/next.d.cts",
        "default": "./dist/presets/next.cjs"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/presets/vite.d.ts",
        "default": "./dist/presets/vite.js"
      },
      "require": {
        "types": "./dist/presets/vite.d.cts",
        "default": "./dist/presets/vite.cjs"
      }
    },
    "./nuxt": {
      "import": {
        "types": "./dist/presets/nuxt.d.ts",
        "default": "./dist/presets/nuxt.js"
      },
      "require": {
        "types": "./dist/presets/nuxt.d.cts",
        "default": "./dist/presets/nuxt.cjs"
      }
    },
    "./astro": {
      "import": {
        "types": "./dist/presets/astro.d.ts",
        "default": "./dist/presets/astro.js"
      },
      "require": {
        "types": "./dist/presets/astro.d.cts",
        "default": "./dist/presets/astro.cjs"
      }
    },
    "./sveltekit": {
      "import": {
        "types": "./dist/presets/sveltekit.d.ts",
        "default": "./dist/presets/sveltekit.js"
      },
      "require": {
        "types": "./dist/presets/sveltekit.d.cts",
        "default": "./dist/presets/sveltekit.cjs"
      }
    },
    "./node": {
      "import": {
        "types": "./dist/presets/node.d.ts",
        "default": "./dist/presets/node.js"
      },
      "require": {
        "types": "./dist/presets/node.d.cts",
        "default": "./dist/presets/node.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "yarn clean && yarn build"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
