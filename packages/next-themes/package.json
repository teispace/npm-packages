{
  "name": "@teispace/next-themes",
  "version": "0.3.2",
  "description": "Feature-rich, lightweight theme management for Next.js and React. Zero-flash SSR, hybrid storage, view transitions, typed themes.",
  "type": "module",
  "license": "MIT",
  "author": "Teispace",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teispace/npm-packages.git",
    "directory": "packages/next-themes"
  },
  "homepage": "https://github.com/teispace/npm-packages/tree/main/packages/next-themes#readme",
  "bugs": {
    "url": "https://github.com/teispace/npm-packages/issues"
  },
  "keywords": [
    "next-themes",
    "theme",
    "dark-mode",
    "nextjs",
    "react",
    "ssr",
    "no-flash",
    "color-scheme",
    "view-transitions",
    "typescript"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.js"
    },
    "./script": {
      "types": "./dist/script.d.ts",
      "import": "./dist/script.js"
    },
    "./tailwind": {
      "types": "./dist/tailwind.d.ts",
      "import": "./dist/tailwind.js"
    },
    "./tailwind.css": "./tailwind.css",
    "./codemod/from-next-themes": "./codemod/from-next-themes.cjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "tailwind.css",
    "codemod",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "yarn build"
  },
  "peerDependencies": {
    "next": ">=13.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jscodeshift": "^17.3.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jscodeshift": "^17.3.0",
    "jsdom": "^29.1.1",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
