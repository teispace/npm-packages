{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    // Published declarations stay fully readable, but ship no `.d.ts.map`
    // sourcemaps (which would point back to / help reconstruct src).
    "declarationMap": false,
    "paths": {
      "@teispace/next-maker": ["./src"]
    }
  },
  "include": ["src/**/*", "types/**/*", "build.ts"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}
