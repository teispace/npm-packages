{
  "name": "npm-packages",
  "private": true,
  "packageManager": "yarn@4.12.0",
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0",
    "yarn": ">=4.0.0"
  },
  "author": "Teispace",
  "license": "MIT",
  "homepage": "https://github.com/teispace/npm-packages#readme",
  "bugs": {
    "url": "https://github.com/teispace/npm-packages/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teispace/npm-packages.git"
  },
  "scripts": {
    "bootstrap": "yarn install",
    "build": "yarn workspaces foreach -A -pt run build",
    "build:packages": "yarn workspaces foreach -A -pt --topological run build",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check --fix .",
    "clean": "rm -rf node_modules .yarn/cache .build dist **/dist coverage",
    "prepare": "husky",
    "postinstall": "husky",
    "commit": "cz",
    "type-check": "tsc --noEmit -p tsconfig.build.json",
    "validate": "yarn lint && yarn type-check && yarn build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=default --reporter=junit",
    "test:workspaces": "yarn workspaces foreach -pt run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
