{
  "name": "npm-packages",
  "private": true,
  "packageManager": "yarn@4.12.0",
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "engines": {
    "node": ">=20.0.0",
    "yarn": ">=4.0.0"
  },
  "author": "Teispace",
  "license": "MIT",
  "homepage": "https://github.com/teispace/npm-packages#readme",
  "bugs": {
    "url": "https://github.com/teispace/npm-packages/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teispace/npm-packages.git"
  },
  "scripts": {
    "bootstrap": "yarn install",
    "build": "yarn workspaces foreach -A -pt run build",
    "build:packages": "yarn workspaces foreach -A -pt --topological run build",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check --fix .",
    "clean": "rm -rf node_modules .yarn/cache .build dist **/dist coverage",
    "prepare": "husky",
    "postinstall": "husky",
    "commit": "cz",
    "type-check": "tsc --noEmit -p tsconfig.build.json",
    "validate": "yarn lint && yarn type-check && yarn build",
    "test": "yarn workspaces foreach -Apt --no-private run test",
    "test:watch": "vitest",
    "test:cov": "yarn workspaces foreach -Apt --no-private run test:cov",
    "test:ci": "yarn workspaces foreach -Apt --no-private run test:cov",
    "test:workspaces": "yarn workspaces foreach -Apt --no-private run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "resolutions": {
    "lexical": "0.44.0",
    "@lexical/react": "0.44.0",
    "@lexical/rich-text": "0.44.0",
    "@lexical/selection": "0.44.0",
    "@lexical/utils": "0.44.0",
    "@lexical/history": "0.44.0",
    "@lexical/html": "0.44.0",
    "@lexical/list": "0.44.0",
    "@lexical/link": "0.44.0",
    "@lexical/code": "0.44.0",
    "@lexical/table": "0.44.0",
    "@lexical/markdown": "0.44.0",
    "@lexical/extension": "0.44.0",
    "@lexical/clipboard": "0.44.0"
  }
}
